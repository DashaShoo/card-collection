# Application
APP_VERSION=1.0.0
NODE_ENV=development
LOG_LEVEL=info
SERVER_INSTANCE=backend-local

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=cards
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
JWT_SECRET=your-super-secret-key-change-in-production
SESSION_TTL=86400

# Deployment
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=card-collection-backend

# ==================
# Builder Stage
# ==================
FROM node:18-alpine AS builder

WORKDIR /app

# Копируем package files - этот слой кешируется если package.json не меняется
COPY package*.json ./

# Устанавливаем зависимости (only production)
RUN npm ci --only=production && npm cache clean --force

# ==================
# Runtime Stage (lightweight)
# ==================
FROM node:18-alpine

WORKDIR /app

# Метаданные сборки
LABEL description="Card Collection Backend API" \
      version="1.0" \
      maintainer="Card Collection Team" \
      environment="production"

# Установка dumb-init для правильной обработки сигналов в контейнере
RUN apk add --no-cache dumb-init

# Копируем node_modules из builder stage (не переинсталлируем)
COPY --from=builder /app/node_modules ./node_modules

# Копируем исходный код (без node_modules)
COPY . .

# Используем dumb-init как entrypoint для правильной передачи сигналов
ENTRYPOINT ["dumb-init", "--"]

# Health check с более коротким start period для быстрого старта
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD node -e "require('http').get('http://localhost:' + (process.env.PORT || 3000), (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})"

# Запускаем приложение
CMD ["npm", "start"]
# Production Environment Configuration
APP_VERSION=1.0.0
NODE_ENV=production

# Database
DB_HOST=prod-db.example.com
DB_PORT=5432
DB_NAME=cards_prod
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_VERY_SECURE_PASSWORD

# Redis
REDIS_HOST=prod-redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_VERY_SECURE_REDIS_PASSWORD

# Security
JWT_SECRET=CHANGE_ME_VERY_SECURE_JWT_SECRET

# Docker
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=yourusername/card-collection-backend
